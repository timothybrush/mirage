{
  "name": "mirage-ts-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "test": "pnpm -r --filter './packages/*' test",
    "typecheck": "pnpm -r --filter './packages/*' typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "release": "pnpm build && changeset publish",
    "mirage": "node packages/cli/dist/bin/mirage.js"
  },
  "pnpm": {
    "overrides": {
      "shell-quote@<1.8.4": ">=1.8.4",
      "esbuild@<0.28.1": ">=0.28.1",
      "protobufjs@>=8.0.0 <8.0.2": "8.0.2"
    }
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1033.0",
    "@aws-sdk/s3-request-presigner": "^3.1033.0",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.39.4",
    "@struktoai/mirage-browser": "workspace:*",
    "@struktoai/mirage-core": "workspace:*",
    "@struktoai/mirage-node": "workspace:*",
    "@types/node": "^22.0.0",
    "aws-sdk-client-mock": "^4.1.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.2",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.2.6"
  }
}
