{
  "name": "@struktoai/mirage-server",
  "version": "0.0.2-alpha.0",
  "description": "A Unified Virtual Filesystem For AI Agents",
  "keywords": [
    "bash",
    "fuse",
    "typescript",
    "vfs",
    "ai-agents",
    "agent-sandbox",
    "langchain",
    "virtual-filesystem",
    "llm-agents",
    "agent-tools",
    "claude-code",
    "openai-agents"
  ],
  "homepage": "https://github.com/strukto-ai/mirage#readme",
  "bugs": {
    "url": "https://github.com/strukto-ai/mirage/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/strukto-ai/mirage.git",
    "directory": "typescript/packages/server"
  },
  "license": "Apache-2.0",
  "author": "Zecheng Zhang <zecheng@strukto.ai>",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./bin/daemon": "./dist/bin/daemon.js"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "mirage-daemon": "./dist/bin/daemon.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/multipart": "^10.0.0",
    "@struktoai/mirage-core": "workspace:*",
    "@struktoai/mirage-node": "workspace:*",
    "fastify": "^5.8.5",
    "isomorphic-git": "^1.38.1",
    "jose": "^6.2.3",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.0",
    "vitest": "^3.2.6"
  }
}
